  "score_display": {
    "high": {
      "icon": "arrow-up-circle",
      "color": "#22C55E",
      "label": "High Score",
      "threshold_min": 70
    },
    "medium": {
      "icon": "minus-circle",
      "color": "#F59E0B",
      "label": "Medium Score",
      "threshold_min": 40
    },
    "low": {
      "icon": "arrow-down-circle",
      "color": "#EF4444",
      "label": "Low Score",
      "threshold_min": 0
    },
    "trend_up": {
      "icon": "trending-up",
      "color": "#22C55E"
    },
    "trend_down": {
      "icon": "trending-down",
      "color": "#EF4444"
    },
    "trend_flat": {
