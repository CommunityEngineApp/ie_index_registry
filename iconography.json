{
  "meta": {
    "name": "IE Platform Iconography",
    "description": "Canonical icon mapping for the IE Community Platform UI. All icon names reference the Lucide icon library (https://lucide.dev), which ships with shadcn/ui and Lovable.",
    "version": "1.0.0",
    "last_updated": "2026-03-14",
    "icon_library": "lucide-react",
    "icon_library_url": "https://lucide.dev/icons"
  },

  "brand": {
    "logo": {
      "icon": "hexagon",
      "label": "Innovative EcoSystems",
      "color": "#0F766E",
      "description": "Primary brand mark — hexagon representing interconnected ecosystems"
    },
    "iepa_badge": {
      "icon": "brain-circuit",
      "label": "IEPA",
      "color": "#7C3AED",
      "description": "IEPA algorithm badge used on score cards and dashboards"
    }
  },

  "zones": {
    "Foundations": {
      "icon": "layers",
      "color": "#2563EB",
      "description": "What a region builds — structural inputs that enable prosperity"
    },
    "Engine": {
      "icon": "cog",
      "color": "#D97706",
      "description": "How prosperity is created — capital and market dynamics"
    },
    "Outcomes": {
      "icon": "trophy",
      "color": "#059669",
      "description": "What success looks like — measurable prosperity results"
    }
  },

  "factors": {
    "Innovation Capacity": {
      "icon": "lightbulb",
      "color": "#3B82F6",
      "zone": "Foundations",
      "description": "R&D, infrastructure, digital readiness, IP, tech adoption"
    },
    "Entrepreneurship Capacity": {
      "icon": "rocket",
      "color": "#8B5CF6",
      "zone": "Foundations",
      "description": "Startup formation, scale-up pathways, access to capital"
    },
    "Resilience": {
      "icon": "shield-check",
      "color": "#10B981",
      "zone": "Foundations",
      "description": "Peace, stability, environment, social cohesion, institutional trust"
    },
    "Alignment": {
      "icon": "git-merge",
      "color": "#6366F1",
      "zone": "Foundations",
      "description": "Government-industry-university coordination and governance quality"
    },
    "FDI Accelerator": {
      "icon": "trending-up",
      "color": "#F59E0B",
      "zone": "Engine",
      "description": "Capital attraction, market access, investment climate"
    },
    "Prosperity Outcomes": {
      "icon": "bar-chart-3",
      "color": "#22C55E",
      "zone": "Outcomes",
      "description": "GDP growth, job creation, scalable company creation"
    }
  },

  "tiers": {
    "Primary": {
      "icon": "star",
      "color": "#EAB308",
      "description": "Core IEPA inputs — required for algorithm computation"
    },
    "Secondary": {
      "icon": "circle-dot",
      "color": "#6B7280",
      "description": "Supplementary inputs — validation and enrichment"
    },
    "Tertiary": {
      "icon": "circle",
      "color": "#D1D5DB",
      "description": "Contextual signals — UI enrichment and scenario analysis"
    }
  },

  "data_access": {
    "Free": {
      "icon": "unlock",
      "color": "#22C55E",
      "description": "Fully open data, downloadable without restriction"
    },
    "Paid": {
      "icon": "lock",
      "color": "#EF4444",
      "description": "Requires paid subscription or license"
    },
    "Partial": {
      "icon": "lock-keyhole",
      "color": "#F59E0B",
      "match_pattern": "Free.*Paid|partial|summary",
      "description": "Summary data free, full dataset requires payment"
    }
  },

  "navigation": {
    "dashboard": {
      "icon": "layout-dashboard",
      "label": "Dashboard"
    },
    "indices": {
      "icon": "database",
      "label": "Index Registry"
    },
    "countries": {
      "icon": "globe",
      "label": "Countries"
    },
    "compare": {
      "icon": "columns-3",
      "label": "Compare"
    },
    "scores": {
      "icon": "calculator",
      "label": "IEPA Scores"
    },
    "methodology": {
      "icon": "book-open",
      "label": "Methodology"
    },
    "settings": {
      "icon": "settings",
      "label": "Settings"
    }
  },

