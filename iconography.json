    },
    "entrepreneurship": {
      "icon": "rocket",
      "tags": ["entrepreneurship", "startups", "startup ecosystems", "unicorns", "scale-up", "business creation", "founder"]
    },
    "governance": {
      "icon": "landmark",
      "tags": ["governance", "government", "regulation", "rule of law", "corruption", "transparency", "policy", "institutions"]
